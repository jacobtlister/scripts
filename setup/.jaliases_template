#!/bin/bash
# File: .jaliases

# path to scripts repository (up here so its line number is constant)
export SCRIPTS_PATH="/path/to/scripts"

: <<'info'
    description
        stores aliases for the scripts in this repository and some additional
        useful aliases. note: jaliases = jacob's aliases

    required packages
        none

    additional notes
        for this to work, the following lines of code must be defined in the
        .bashrc file in your home directory:

            if [ -f ~/.jaliases ]; then
                . ~/.jaliases
            fi

        you can add this manually or by runnning setupjaliases.sh in
        scripts/setup/ (this directory!)
info

# aliases for scripts
alias vgto="bash ${SCRIPTS_PATH}/converters/vgto.sh"
alias videotoav1="bash ${SCRIPTS_PATH}/converters/videotoav1.sh"

alias imagetopdf="bash ${SCRIPTS_PATH}/pdf/imagetopdf.sh"
alias pdfmerge="bash ${SCRIPTS_PATH}/pdf/pdfmerge.sh"
alias pdfweave="bash ${SCRIPTS_PATH}/pdf/pdfweave.sh"
alias topdf="bash ${SCRIPTS_PATH}/pdf/topdf.sh"

# convenient alias to make navigating directories in a terminal easier
alias ..="cd .."

# lets you look at the manual from a package selected from a list of all
# installed packages
alias fman="compgen -c | fzf | xargs man"
